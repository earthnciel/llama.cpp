#!/usr/bin/env bash
# pre-commit — block secrets / sensitive data from entering this PUBLIC fork.
# Enforces the "Fork governance" rule #3 in CLAUDE.md.
#
# Scope: scans only the ADDED lines of staged (Added/Modified) files.
# Skipped during merges: merged content comes from upstream (already public).
# Email addresses are intentionally NOT flagged (the owner treats email as an
# acceptable-to-expose indirect contact; only direct-contact phone/mobile
# numbers are sensitive).
#
# Bypass (use ONLY when you have confirmed a false positive):
#   git commit --no-verify
set -u

git_dir="$(git rev-parse --git-dir)"

# Merge commits carry upstream code — don't rescan it here.
if [ -f "$git_dir/MERGE_HEAD" ]; then
    exit 0
fi

# High-signal patterns (extended regex, case-insensitive). Kept tight on purpose:
# a noisy hook gets --no-verify'd into uselessness.
patterns='(-----BEGIN [A-Z ]*PRIVATE KEY-----)'                                   # PEM private keys
patterns="$patterns"'|(AKIA[0-9A-Z]{16})'                                         # AWS access key id
patterns="$patterns"'|(gh[pousr]_[A-Za-z0-9]{30,})'                               # GitHub tokens
patterns="$patterns"'|(sk-[A-Za-z0-9]{20,})'                                      # OpenAI-style keys
patterns="$patterns"'|(xox[baprs]-[A-Za-z0-9-]{10,})'                             # Slack tokens
patterns="$patterns"'|((api[_-]?key|secret|token|passwd|password|auth[_-]?key|access[_-]?token|client[_-]?secret|bearer)[[:space:]]*[:=][[:space:]]*['"'"'"]?[A-Za-z0-9/_+.=-]{8,})'  # key = value
patterns="$patterns"'|(\b10(\.[0-9]{1,3}){3}\b)'                                  # private IPv4 range 10.x
patterns="$patterns"'|(\b192\.168(\.[0-9]{1,3}){2}\b)'                            # private IPv4 range 192.168.x
patterns="$patterns"'|(\b172\.(1[6-9]|2[0-9]|3[01])(\.[0-9]{1,3}){2}\b)'          # private IPv4 range 172.16-31.x
patterns="$patterns"'|(\b01[016789][-. ]?[0-9]{3,4}[-. ]?[0-9]{4}\b)'             # KR mobile number

found=0
report=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    added="$(git diff --cached --unified=0 --no-color -- "$f" | grep '^+' | grep -v '^+++')"
    [ -z "$added" ] && continue
    hits="$(printf '%s\n' "$added" | sed 's/^+//' | grep -Ei "$patterns" || true)"
    if [ -n "$hits" ]; then
        found=1
        report="${report}
  ${f}:
$(printf '%s\n' "$hits" | sed 's/^/      /')"
    fi
done < <(git diff --cached --name-only --diff-filter=AM)

if [ "$found" -ne 0 ]; then
    echo "✖ pre-commit: 잠재적 민감정보가 감지되어 커밋을 차단합니다 (CLAUDE.md governance #3)." >&2
    echo "$report" >&2
    echo "" >&2
    echo "  오탐이 확실하면:  git commit --no-verify" >&2
    exit 1
fi

exit 0
